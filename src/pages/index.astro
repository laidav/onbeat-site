---
import ContactForm from '../components/ContactForm.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <section id="hero">
		<div class="container">
			<h1>Be in sync with your data and amplify your insights.</h1>
			<h3>Leverage insights with AI, streamline operations with confidence, and stay perfectly in sync with your business goals.</h3>
		</div>
  </section>
  <section id="what-we-do">
		<div class="container">
			<h2>What we do</h2>
			<ul class="row">
				<li>
					<h3>Capture complex data and turn it into actionable insights</h3>
					<p>Powered by resilient backend infrastructure, our dynamic forms simplify the management of complex business entities — so you can make smarter, faster decisions.</p>
				</li>
				<li>
					<h3>Reveal patterns and anomalies with AI and thoughtful design</h3>
					<p>We uncover what matters most, helping you stay responsive and proactive.</p>
				</li>
				<li>
					<h3>Deliver elegant digital solutions with seamless UI/UX</h3>
					<p>Elegant design and intuitive interfaces transform complexity into clarity—so your business always stays on beat.</p>
				</li>
			</ul>
	  </div>
  </section>
	<section class="contact-us">
		<div class="container">
			<div class="row">
				<div class="contact-us__copy">
					<h3>Get in touch</h3>
				</div>
				<div class="contact-us__form">
					<ContactForm />
				</div>
			</div>
		</div>

	</section>
</Layout>

<style lang="scss">
	.contact-us {
		&__copy {
			display: flex;
			justify-content: center;
			align-items: center;

			h3 {
				text-align: center;
				color: var(--color-primary);
				font-weight: 500;
				font-size: 48px;
			}
		}

		.row {
			flex-direction: column;

			@media  screen and (min-width:768px) {
				flex-direction: row;
			}
		}

		&__copy, &__form {
			flex-grow: 1;
		}

	}

</style>
