---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <section id="hero">
		<div class="container">
			<h1>Data Simplified. Insights Amplified.</h1>
			<h3>Apply your business knowledge, act on insights, and streamline operations with confidence.</h3>
		</div>
  </section>
  <section id="what-we-do">
		<div class="container">
    <h2>What we do</h2>
    <ul>
      <li>
        <h3>Capture complex data and turn it into actionable insights</h3>
        <p>With dynamic forms powered by resilient infrastructure, managing multiple business entities for smarter, faster decisions.</p>
      </li>
      <li>
        <h3>Reveal patterns and anomalies with AI and thoughtful design</h3>
        <p>Uncover what matters most.</p>
      </li>
      <li>
        <h3>Deliver elegant digital solutions with seamless UI/UX</h3>
        <p>Turning complexity into clarity.</p>
      </li>
    </ul>
	</div>
  </section>
</Layout>
